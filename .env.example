# Copy to .env.local (never commit .env.local) and set the same keys in Vercel
# → Project → Settings → Environment Variables (Production + Preview).

# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Where Contact Us submissions land
CONTACT_TO_EMAIL=sales@cellsitesolutions.com
# Must be on a Resend-verified sending domain
CONTACT_FROM_EMAIL=website@cellsitesolutions.com
# From address for ebook download emails (verified domain)
EBOOK_FROM_EMAIL=downloads@cellsitesolutions.com

# Canonical site URL (used for metadata, sitemap, absolute links)
NEXT_PUBLIC_SITE_URL=https://www.cellsitesolutions.com

# Optional spam protection (Cloudflare Turnstile) — recommended
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
